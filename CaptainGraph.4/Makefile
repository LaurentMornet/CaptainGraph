dist: distdir FORCE
	(cd `dirname $(DISTDIR)` && $(TAR) $(DISTNAME).tar $(DISTNAME) && $(COMPRESS) $(DISTNAME).tar) && $(MOVE) `dirname $(DISTDIR)`/$(DISTNAME).tar.gz . && $(DEL_FILE) -r $(DISTDIR)

distdir: FORCE
	@test -d $(DISTDIR) || mkdir -p $(DISTDIR)
	$(COPY_FILE) --parents $(DIST) $(DISTDIR)/
	$(COPY_FILE) --parents resources/resources.qrc $(DISTDIR)/
	$(COPY_FILE) --parents src/main.h src/common/manager.h src/common/configuration.h src/common/page.h src/common/graph.h src/common/plot.h src/adapter/manager_adapter.h src/adapter/configuration_adapter.h src/adapter/page_adapter.h src/adapter/graph_adapter.h src/adapter/plot_adapter.h src/adapter/style_adapter.h src/ihm/ihm_tools.h src/ihm/main_window.h src/ihm/graph_frame.h src/ihm/plot_frame.h src/ihm/plot_style.h src/ihm/configuration_frame.h src/ihm/resizable_snap_rect_item.h $(DISTDIR)/
	$(COPY_FILE) --parents src/main.cpp src/common/manager.cpp src/common/configuration.cpp src/common/page.cpp src/common/graph.cpp src/common/plot.cpp src/common/plot_database.cpp src/adapter/manager_adapter.cpp src/adapter/configuration_adapter.cpp src/adapter/page_adapter.cpp src/adapter/graph_adapter.cpp src/adapter/plot_adapter.cpp src/adapter/style_adapter.cpp src/ihm/ihm_tools.cpp src/ihm/main_window.cpp src/ihm/graph_frame.cpp src/ihm/plot_frame.cpp src/ihm/plot_style.cpp src/ihm/configuration_frame.cpp src/ihm/resizable_snap_rect_item.cpp $(DISTDIR)/


