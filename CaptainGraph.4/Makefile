project.app/Contents/PkgInfo: 
	@test -d project.app/Contents || mkdir -p project.app/Contents
	@$(DEL_FILE) project.app/Contents/PkgInfo
	@echo "APPL????" > project.app/Contents/PkgInfo
project.app/Contents/Resources/empty.lproj: 
	@test -d project.app/Contents/Resources || mkdir -p project.app/Contents/Resources
	@touch project.app/Contents/Resources/empty.lproj
	
project.app/Contents/Info.plist: 
	@test -d project.app/Contents || mkdir -p project.app/Contents
	@$(DEL_FILE) project.app/Contents/Info.plist
	@sed -e "s,@SHORT_VERSION@,1.0,g" -e "s,\$${QMAKE_SHORT_VERSION},1.0,g" -e "s,@FULL_VERSION@,1.0.0,g" -e "s,\$${QMAKE_FULL_VERSION},1.0.0,g" -e "s,@TYPEINFO@,????,g" -e "s,\$${QMAKE_PKGINFO_TYPEINFO},????,g" -e "s,@BUNDLEIDENTIFIER@,chez.project,g" -e "s,\$${PRODUCT_BUNDLE_IDENTIFIER},chez.project,g" -e "s,\$${MACOSX_DEPLOYMENT_TARGET},10.14,g" -e "s,\$${IPHONEOS_DEPLOYMENT_TARGET},,g" -e "s,\$${TVOS_DEPLOYMENT_TARGET},,g" -e "s,\$${WATCHOS_DEPLOYMENT_TARGET},,g" -e "s,\$${IOS_LAUNCH_SCREEN},LaunchScreen,g" -e "s,@ICON@,,g" -e "s,\$${ASSETCATALOG_COMPILER_APPICON_NAME},,g" -e "s,@EXECUTABLE@,project,g" -e "s,@LIBRARY@,project,g" -e "s,\$${EXECUTABLE_NAME},project,g" -e "s,@TYPEINFO@,????,g" -e "s,\$${QMAKE_PKGINFO_TYPEINFO},????,g" /opt/qt6.4.3/macos/mkspecs/macx-clang/Info.plist.app >project.app/Contents/Info.plist

